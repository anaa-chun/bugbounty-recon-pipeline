{
  "telegram": {
    "bot_token": "", # el api que te da
    "chat_id": "", # pones el id que te da
    "enabled": true
  },
  "subfinder": {
    "sources": ["all"],
    "timeout": 30,
    "rate_limit": 10
  },
  "dnsx": {
    "resolver": "8.8.8.8",
    "wildcard_filter": true
  },
  "httpx": {
    "timeout": 10,
    "threads": 50,
    "follow_redirects": true,
    "status_code": true,
    "title": true,
    "tech_detect": true
  },
  "gowitness": {
    "threads": 4,
    "timeout": 10,
    "resolution": "1920x1080"
  },
  "nuclei": {
    "templates": "latest",
    "severity": "critical,high,medium",
    "rate_limit": 150,
    "concurrency": 25
  },
  "output": {
    "save_json": true,
    "save_html": true,
    "notify_new_subdomains": true
  }
}
